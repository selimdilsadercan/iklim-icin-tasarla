{
  "name": "iklim-eval",
  "version": "1.0.0",
  "description": "Öğrenci mesaj analizi ve değerlendirme sistemi",
  "main": "main.py",
  "scripts": {
    "docker:build": "docker build -t iklim-eval .",
    "docker:run": "docker run --rm -p 8000:8000 --env-file .env iklim-eval",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "eval": ".\\venv\\Scripts\\python.exe main.py",
    "eval:local": "python main.py",
    "setup": "setup.bat",
    "api": ".\\venv\\Scripts\\python.exe app.py",
    "api:local": "python app.py",
    "install-py": ".\\venv\\Scripts\\python.exe -m pip install -r requirements.txt",
    "install-py:local": "python -m pip install -r requirements.txt",
    "venv-create": "python -m venv venv",
    "notebook": ".\\venv\\Scripts\\jupyter.exe notebook",
    "notebook:local": "python -m jupyter notebook"
  },
  "keywords": [
    "python",
    "education",
    "llm",
    "evaluation"
  ],
